{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=jobtracker;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_USE_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "ExpiryDays": 30
  },
  "Anthropic": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY_HERE"
  },
  "AzureStorage": {
    "ConnectionString": "PLACEHOLDER_AZURE_STORAGE_CONNECTION_STRING",
    "ContainerName": "resumes"
  },
  "AllowedExtensions": [
    "chrome-extension://PLACEHOLDER_EXTENSION_ID"
  ]
}
